{
  "name": "revenuepulse",
  "version": "1.0.0",
  "description": "Revenue analytics dashboard app for Shopify merchants",
  "main": "app.js",
  "type": "module",
  "scripts": {
    "build": "esbuild app/frontend/src/index.jsx --bundle --outfile=app/frontend/dist/bundle.js --loader:.jsx=jsx --define:process.env.NODE_ENV=production",
    "start": "node app.js",
    "dev": "node --watch app.js"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "pg": "^8.11.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sql.js": "^1.14.1",
    "uuid": "^9.0.1"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "esbuild": "^0.28.0"
  }
}
