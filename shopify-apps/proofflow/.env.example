# ProofFlow Environment Configuration Example
# Copy this file to .env and fill in your values

# ===========================================
# SHOPIFY API CREDENTIALS
# ===========================================

# Your Shopify API key from the Partner Dashboard
SHOPIFY_API_KEY=your_s...here

# Your Shopify API secret
SHOPIFY_API_SECRET=your_s...here

# ===========================================
# APP CONFIGURATION
# ===========================================

# Public URL of your app (required for OAuth callbacks)
# For local development, use ngrok or similar
APP_URL=https://your-app-url.ngrok.io

# Port to run the server on
PORT=3001

# Node environment
NODE_ENV=development

# ===========================================
# DATABASE
# ===========================================

# Path to SQLite database file
DATABASE_PATH=./data/proofflow.db

# ===========================================
# SESSION SECURITY
# ===========================================

# Random 32-byte hex string for session encryption
# Generate with: openssl rand -hex 32
SESSION_SECRET=change...ring

# ===========================================
# WEBHOOK VERIFICATION
# ===========================================

# Webhook secret (if different from API secret)
WEBHOOK_SECRET=your_w...here
